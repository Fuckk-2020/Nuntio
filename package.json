{
  "name": "nuntio",
  "version": "1.0.0",
  "description": "Nuntio - Pomodoro App",
  "main": "electron.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.nuntio.app",
    "productName": "Nuntio",
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron.js"
    ]
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.5.0",
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^7.3.1"
  }
}